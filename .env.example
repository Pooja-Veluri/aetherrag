# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

# ── AWS Bedrock (required) ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required only for temporary/session credentials (AWS Academy, SSO, AssumeRole)
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ── OpenSearch (required for hybrid retrieval) ────────────────────────────
OPENSEARCH_URL=http://localhost:9200

# ── LangSmith tracing (optional) ──────────────────────────────────────────
# Either var name works. Tracing is on by default in app.py; without an API
# key the calls degrade to local-only no-ops.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aetherrag
LANGCHAIN_TRACING_V2=true

# ── Bedrock Guardrails (optional) ─────────────────────────────────────────
# When set, every InvokeModel call is filtered through this guardrail.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Semantic cache tuning (optional) ──────────────────────────────────────
SEMANTIC_CACHE_DB=./semantic_cache.db
SEMANTIC_CACHE_THRESHOLD=0.93
SEMANTIC_CACHE_MAX_ROWS=5000
SEMANTIC_CACHE_TTL_SECONDS=0
